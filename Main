# STEP 2: Import libraries
import whisper
from google.colab import files
from docx import Document
import torch

# STEP 3: Check GPU availability and set device
device = "cuda" if torch.cuda.is_available() else "cpu"
print(f"Using device: {device}")

# STEP 4: Upload your audio file
uploaded = files.upload()

# STEP 5: Load Whisper model on appropriate device
# استفاده از مدل large برای دقت بیشتر (با GPU سریعتر خواهد بود)
model = whisper.load_model("large", device=device)
print(f"Model loaded on: {next(model.parameters()).device}")


# STEP 6: Transcribe the audio file with GPU acceleration
audio_path = list(uploaded.keys())[0]
print("Starting transcription...")

# تنظیمات اضافی برای بهبود دقت و سرعت
result = model.transcribe(
    audio_path,
    fp16=(device == "cuda"),  # استفاده از محاسبات 16 بیتی اگر GPU موجود باشد
    #language='fa'  # مشخص کردن زبان فارسی برای دقت بیشتر (اختیاری)
)

transcript = result["text"]
print("Transcription completed!")
# STEP 7: Save transcription to a Word (.docx) file
doc = Document()
doc.add_heading("Audio Transcription", 0)
doc.add_paragraph(transcript)

docx_filename = "transcription_output.docx"
doc.save(docx_filename)

# STEP 8: Download the .docx file
files.download(docx_filename)

print("Process completed successfully!")

