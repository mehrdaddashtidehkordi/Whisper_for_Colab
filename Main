# STEP 2: Import libraries
import whisper
from google.colab import files
import torch
from fpdf import FPDF
import os

# STEP 3: Check GPU availability
device = "cuda" if torch.cuda.is_available() else "cpu"
print(f"Using device: {device}")

# STEP 4: Upload audio file
uploaded = files.upload()

# STEP 5: Load Whisper model
model = whisper.load_model("large", device=device)
print(f"Model loaded on: {next(model.parameters()).device}")

# STEP 6: Transcribe with German language setting
audio_path = list(uploaded.keys())[0]
print("Starting transcription...")

result = model.transcribe(
    audio_path,
    fp16=(device == "cuda"),
    language='de',  # for German - en for English
    task='transcribe'
)

transcript = result["text"]
print("Transcription completed!")

# STEP 7: Create and save PDF
pdf = FPDF()
pdf.add_page()

# support German chars
pdf.add_font('DejaVu', '', '/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf', uni=True)
pdf.add_font('DejaVu', 'B', '/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf', uni=True)

# title
pdf.set_font('DejaVu', 'B', 16)
pdf.cell(0, 10, 'Audio Transcription', ln=True, align='C')
pdf.ln(10)

# main text
pdf.set_font('DejaVu', '', 12)
pdf.multi_cell(0, 10, transcript)

# save file
pdf_filename = "transcription_output.pdf"
pdf.output(pdf_filename)

# STEP 8: Download PDF
files.download(pdf_filename)

print("Process completed successfully!")
